# ============================================================
# IMPORTS
# ============================================================

import os
import re
import random
import numpy as np
import pandas as pd
from tqdm import tqdm

import nltk
import spacy
import textstat

import matplotlib.pyplot as plt
import seaborn as sns

from collections import Counter

nltk.download("punkt")

# ============================================================
# REPRODUCIBILITY
# ============================================================

SEED = 42

random.seed(SEED)
np.random.seed(SEED)

# ============================================================
# LOAD SPACY
# ============================================================

nlp = spacy.load("en_core_web_sm")

# ============================================================
# CREATE DIRECTORIES
# ============================================================

os.makedirs("data/raw", exist_ok=True)
os.makedirs("data/processed", exist_ok=True)
os.makedirs("outputs/plots", exist_ok=True)

# ============================================================
# DOWNLOAD PROJECT GUTENBERG FILES
# ============================================================

# Jane Austen
!wget -O data/raw/pride_and_prejudice.txt https://www.gutenberg.org/files/1342/1342-0.txt

# Charles Dickens
!wget -O data/raw/great_expectations.txt https://www.gutenberg.org/files/1400/1400-0.txt

# ============================================================
# PREPROCESSING FUNCTIONS
# ============================================================

def read_txt(path):

    with open(path, "r", encoding="utf-8") as f:

        text = f.read()

    return text


def clean_gutenberg(text):

    start_patterns = [
        "*** START OF",
        "***START OF"
    ]

    end_patterns = [
        "*** END OF",
        "***END OF"
    ]

    start_idx = 0
    end_idx = len(text)

    for pattern in start_patterns:

        if pattern in text:

            start_idx = text.find(pattern)

            break

    for pattern in end_patterns:

        if pattern in text:

            end_idx = text.find(pattern)

            break

    text = text[start_idx:end_idx]

    # remove multiple spaces
    text = re.sub(r"\s+", " ", text)

    # normalize quotes
    text = text.replace("“", '"')
    text = text.replace("”", '"')

    return text


def split_paragraphs(text, min_words=80):

    paras = re.split(r"\n\s*\n", text)

    cleaned = []

    for p in paras:

        p = p.strip()

        if len(p.split()) < min_words:
            continue

        # remove chapter titles
        lower = p.lower()

        if lower.startswith("chapter"):
            continue

        if lower.startswith("book"):
            continue

        if "project gutenberg" in lower:
            continue

        if "illustration" in lower:
            continue

        cleaned.append(p)

    return cleaned

# ============================================================
# FEATURE EXTRACTION
# ============================================================

def type_token_ratio(words):

    if len(words) == 0:
        return 0

    return len(set(words)) / len(words)


def hapax_legomena(words):

    counts = Counter(words)

    return sum(1 for w, c in counts.items() if c == 1)


def avg_dependency_depth(doc):

    depths = []

    for sent in doc.sents:

        depth = 0

        for token in sent:

            current = token
            current_depth = 0

            while current.head != current:

                current = current.head
                current_depth += 1

            depth = max(depth, current_depth)

        depths.append(depth)

    if len(depths) == 0:
        return 0

    return np.mean(depths)


def punctuation_density(text):

    total = max(len(text.split()), 1)

    return {

        "semicolon":
            text.count(";") / total,

        "emdash":
            text.count("—") / total,

        "exclamation":
            text.count("!") / total,

        "colon":
            text.count(":") / total,

        "comma":
            text.count(",") / total
    }


def extract_features(text):

    doc = nlp(text)

    words = [
        token.text.lower()
        for token in doc
        if token.is_alpha
    ]

    word_count = len(words)

    unique_words = len(set(words))

    pos_counts = Counter([
        token.pos_
        for token in doc
    ])

    nouns = pos_counts.get("NOUN", 1)

    adjectives = pos_counts.get("ADJ", 0)

    adj_noun_ratio = adjectives / nouns

    sent_lengths = [
        len(sent.text.split())
        for sent in doc.sents
    ]

    avg_sent_len = np.mean(sent_lengths) if len(sent_lengths) > 0 else 0

    punct = punctuation_density(text)

    features = {

        "word_count":
            word_count,

        "char_count":
            len(text),

        "unique_words":
            unique_words,

        "ttr":
            type_token_ratio(words),

        "hapax":
            hapax_legomena(words),

        "adj_noun_ratio":
            adj_noun_ratio,

        "avg_sent_len":
            avg_sent_len,

        "dep_depth":
            avg_dependency_depth(doc),

        "fkg":
            textstat.flesch_kincaid_grade(text),

        **punct
    }

    return features

# ============================================================
# BUILD DATASET
# ============================================================

local_files = {

    "Jane Austen": [
        "data/raw/pride_and_prejudice.txt"
    ],

    "Charles Dickens": [
        "data/raw/great_expectations.txt"
    ]
}

rows = []

for author, files in local_files.items():

    for fp in files:

        raw = read_txt(fp)

        clean = clean_gutenberg(raw)

        paras = split_paragraphs(
            clean,
            min_words=80
        )

        for p in paras:

            rows.append({

                "text": p,

                "author": author,

                "binary_label": 0,

                "class_label": "human",

                "source_file": fp,

                "word_count_raw":
                    len(p.split())
            })

# ============================================================
# CREATE DATAFRAME
# ============================================================

human_df = pd.DataFrame(rows)

print("\nDATASET SIZE:")
print(human_df.shape)

print("\nAUTHOR DISTRIBUTION:")
print(human_df.groupby("author").size())

# ============================================================
# BALANCE AUTHORS
# ============================================================

min_size = human_df.groupby("author").size().min()

human_df = human_df.groupby(
    "author"
).sample(
    n=min_size,
    random_state=SEED
)

human_df = human_df.reset_index(drop=True)

print("\nBALANCED DATASET:")
print(human_df.groupby("author").size())

# ============================================================
# SAVE HUMAN CORPUS
# ============================================================

human_df.to_csv(
    "data/processed/human_corpus.csv",
    index=False
)

print("\nSaved human_corpus.csv")

# ============================================================
# FEATURE EXTRACTION
# ============================================================

feature_rows = []

for text in tqdm(human_df["text"].tolist()):

    try:

        feature_rows.append(
            extract_features(text)
        )

    except Exception as e:

        print("Feature extraction failed")

        feature_rows.append({})

feature_df = pd.DataFrame(feature_rows)

print("\nFEATURE DATAFRAME:")
print(feature_df.head())

print("\nFEATURE SHAPE:")
print(feature_df.shape)

# ============================================================
# MERGE FEATURES
# ============================================================

stylometry_df = pd.concat(

    [
        human_df.reset_index(drop=True),
        feature_df.reset_index(drop=True)
    ],

    axis=1
)

# ============================================================
# SAVE STYLOMETRY DATASET
# ============================================================

stylometry_df.to_csv(
    "data/processed/human_stylometry.csv",
    index=False
)

print("\nSaved human_stylometry.csv")

# ============================================================
# VISUALIZATION
# ============================================================

sns.set_style("whitegrid")

# ============================================================
# PARAGRAPH LENGTH DISTRIBUTION
# ============================================================

plt.figure(figsize=(10,6))

sns.histplot(
    stylometry_df["word_count"],
    bins=30,
    kde=True
)

plt.title(
    "Paragraph Length Distribution"
)

plt.xlabel("Word Count")

plt.savefig(
