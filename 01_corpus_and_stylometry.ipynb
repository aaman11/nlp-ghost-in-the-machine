import pandas as pd
from tqdm import tqdm
from preprocessing import read_txt, clean_gutenberg, split_paragraphs
from feature_engineering import extract_features

local_files = {
    "Jane Austen": ["1342-0.txt"],
    "Charles Dickens": ["1400-0.txt"]
}

rows = []
for author, files in local_files.items():
    for fp in files:
        raw = read_txt(fp)
        clean = clean_gutenberg(raw)
        paras = split_paragraphs(clean, min_words=80)
        for p in paras:
            rows.append({"text": p, "author": author, "label": 0, "source": "human"})

human_df = pd.DataFrame(rows)
human_df.to_csv("data/human_corpus.csv", index=False)

feat_rows = [extract_features(t) for t in tqdm(human_df["text"].tolist())]
feat_df = pd.DataFrame(feat_rows)
stylometry_df = pd.concat([human_df.reset_index(drop=True), feat_df], axis=1)
stylometry_df.to_csv("data/human_stylometry.csv", index=False)
