)

plt.show()

# ============================================================
# TTR DISTRIBUTION
# ============================================================

plt.figure(figsize=(10,6))

sns.boxplot(
    data=stylometry_df,
    x="author",
    y="ttr"
)

plt.title(
    "Type Token Ratio by Author"
)

plt.savefig(
    "outputs/plots/ttr_by_author.png"
)

plt.show()

# ============================================================
# READABILITY DISTRIBUTION
# ============================================================

plt.figure(figsize=(10,6))

sns.boxplot(
    data=stylometry_df,
    x="author",
    y="fkg"
)

plt.title(
    "Flesch-Kincaid Grade by Author"
)

plt.savefig(
    "outputs/plots/readability_by_author.png"
)

plt.show()

# ============================================================
# PUNCTUATION HEATMAP
# ============================================================

punct_cols = [
    "semicolon",
    "emdash",
    "exclamation",
    "colon",
    "comma"
]

heatmap_df = stylometry_df.groupby(
    "author"
)[punct_cols].mean()

plt.figure(figsize=(8,5))

sns.heatmap(
    heatmap_df,
    annot=True,
    cmap="viridis"
)

plt.title(
    "Punctuation Density Heatmap"
)

plt.savefig(
    "outputs/plots/punctuation_heatmap.png"
)

plt.show()

# ============================================================
# FEATURE CORRELATION
# ============================================================

numeric_cols = [

    "ttr",
    "hapax",
    "adj_noun_ratio",
    "avg_sent_len",
    "dep_depth",
    "fkg",
    "semicolon",
    "emdash",
    "exclamation",
    "colon",
    "comma"
]

corr = stylometry_df[numeric_cols].corr()

plt.figure(figsize=(12,10))

sns.heatmap(
    corr,
    cmap="coolwarm",
    annot=False
)

plt.title(
    "Stylometric Feature Correlation"
)

plt.savefig(
    "outputs/plots/feature_correlation.png"
)

plt.show()

# ============================================================
# SUMMARY STATISTICS
# ============================================================

summary = stylometry_df.groupby(
    "author"
)[numeric_cols].mean()

print("\nSUMMARY STATISTICS:")
print(summary)

summary.to_csv(
    "outputs/author_feature_summary.csv"
)

# ============================================================
# DONE
# ============================================================

print("\nPipeline completed successfully.")
print("Files saved in:")
